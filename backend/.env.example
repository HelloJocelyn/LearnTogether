# Copy to .env and set values. backend/.env is gitignored.
#
# OPENAI_API_KEY=sk-...
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_CHAT_MODEL=gpt-4o-mini
# CHECKIN_TZ=Asia/Tokyo
# APP_ENV=local
# CHECKIN_CONFIG_FILE=
# DATABASE_URL=sqlite:///./app.db
# DAILY_HERO_DIR=
# BADGE_CERT_DIR=   # optional; default backend/data/badge_certificates
